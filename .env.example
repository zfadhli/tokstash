# Telegram Configuration
# 1. Get API ID + hash: https://my.telegram.org/apps
# 2. Create a bot: message @BotFather on Telegram → /newbot → get token
# 3. Get your chat ID: message @userinfobot on Telegram
# 4. Rename this file to .env and fill in your values

TELEGRAM_API_ID="123456"
TELEGRAM_API_HASH="your_api_hash_here"
TELEGRAM_BOT_TOKEN="1234567890:ABCdefGHIjkl-mnoPQRstuvWXyz"
TELEGRAM_CHAT_ID="123456789"
