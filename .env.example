# Telegram Configuration
# 1. Create a bot: message @BotFather on Telegram → /newbot → get token
# 2. Get your chat ID: message @userinfobot on Telegram
# 3. Rename this file to .env and fill in your values

TELEGRAM_BOT_TOKEN="1234567890:ABCdefGHIjkl-mnoPQRstuvWXyz"
TELEGRAM_CHAT_ID="123456789"

# Optional: TikTok session cookies for private livestreams
# Log into TikTok in your browser, then copy cookies from DevTools
# TIKTOK_COOKIES="sessionid=abc123; tt_chain_token=def456"

# Optional: GitHub token for automated releases
# GH_TOKEN="ghp_xxxxxxxxxxxxxxxxxxxx"
